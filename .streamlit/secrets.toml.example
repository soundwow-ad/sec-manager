# 這是 secrets.toml 的範例檔案
# 請複製此檔案為 secrets.toml 並填入實際的 API Key
# 注意：secrets.toml 已經在 .gitignore 中，不會被上傳到 Git

[ragic]
api_key = "YOUR_RAGIC_API_KEY_HERE"

# Google Sheet 當資料庫（選用）：免費版 Streamlit 重啟後可從 Sheet 還原資料
# 試算表需「分享」給服務帳戶的 client_email（編輯權限）
# 方式一：整份憑證 JSON 放進 TOML（可用單行或多行字串）
[google_sheet]
enabled = true
sheet_id = "YOUR_GOOGLE_SHEET_ID"
# credentials = { ... }   # 或 credentials_json = "{\"type\":\"service_account\", ... }"

# 方式二：只填 client_email 與 private_key（較適合 TOML）
# [google_sheet]
# enabled = true
# sheet_id = "YOUR_GOOGLE_SHEET_ID"
# client_email = "xxx@xxx.iam.gserviceaccount.com"
# private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
